    {
      "name": "02. Provinces",
      "item": [
        {
          "name": "Get All Provinces",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response structure is valid\", function () {",
                  "    pm.expect(response.statusCode).to.eql(200);",
                  "    pm.expect(response.data).to.be.an('array');",
                  "});",
                  "if (response.data && response.data.length > 0) {",
                  "    // Dynamic Variable Assignment for subsequent testing",
                  "    var firstProvince = response.data[0];",
                  "    pm.collectionVariables.set(\"provinceId\", firstProvince.id);",
                  "    pm.collectionVariables.set(\"provinceCode\", firstProvince.code);",
                  "    console.log(\"Set provinceId to: \" + firstProvince.id);",
                  "    console.log(\"Set provinceCode to: \" + firstProvince.code);",
                  "    ",
                  "    // Verify properties of first object",
                  "    pm.test(\"Province entity matches expected schema\", function () {",
                  "        pm.expect(firstProvince).to.have.property('id');",
                  "        pm.expect(firstProvince).to.have.property('name');",
                  "        pm.expect(firstProvince).to.have.property('code');",
                  "        pm.expect(firstProvince).to.have.property('hasProject');",
                  "        pm.expect(firstProvince).to.have.property('centerCount');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/provinces",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "provinces"
              ]
            },
            "description": "Retrieve list of all provinces sorted alphabetically by name. Public access."
          },
          "response": []
        },
        {
          "name": "Get Province by Code - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "var expectedCode = pm.collectionVariables.get(\"provinceCode\");",
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Province matches requested code\", function () {",
                  "    pm.expect(response.statusCode).to.eql(200);",
                  "    pm.expect(response.data.code).to.eql(expectedCode);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/provinces/:code",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "provinces",
                ":code"
              ],
              "variable": [
                {
                  "key": "code",
                  "value": "{{provinceCode}}",
                  "description": "Short code of the province (dynamic)"
                }
              ]
            },
            "description": "Retrieve details of a specific province by its code. Public access."
          },
          "response": []
        },
        {
          "name": "Get Province by Code - Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test(\"Status code is 404 Not Found\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "pm.test(\"Error response matches message pattern\", function () {",
                  "    pm.expect(response.statusCode).to.eql(404);",
                  "    pm.expect(response.message).to.contain(\"Không tìm thấy tỉnh\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/provinces/:code",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "provinces",
                ":code"
              ],
              "variable": [
                {
                  "key": "code",
                  "value": "XYZ_NONEXISTENT",
                  "description": "Short code of the province (invalid)"
                }
              ]
            },
            "description": "Retrieving details of a non-existent province should fail with a 404 status code."
          },
          "response": []
        },
        {
          "name": "Update Province Details - Success (Superadmin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Province was updated with new values\", function () {",
                  "    pm.expect(response.statusCode).to.eql(200);",
                  "    pm.expect(response.data.hasProject).to.eql(true);",
                  "    pm.expect(response.data.centerCount).to.eql(5);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
