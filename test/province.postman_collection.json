                  "pm.test(\"Status code is 400 Bad Request\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test(\"Validation error messages are present\", function () {",
                  "    pm.expect(response.statusCode).to.eql(400);",
                  "    pm.expect(response.message).to.be.an('array');",
                  "    var msgStr = response.message.join(', ');",
                  "    pm.expect(msgStr).to.contain(\"hasProject\");",
